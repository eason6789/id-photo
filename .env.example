# 阿里百炼API配置
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_API_KEY_BACKUP=your-backup-api-key-here

# 服务端口
AI_SERVICE_PORT=8091
GO_SERVICE_PORT=8090
HIVISION_SERVICE_PORT=8080

# 数据库配置
DB_USER=root
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=3306
DB_NAME=wish_plan

# 管理员密码
ADMIN_PASSWORD=your-password-here

# 上传目录
UPLOAD_DIR=./uploads

# 日志级别
LOG_LEVEL=info
